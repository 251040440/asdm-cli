# ASDM Bootstrapper CLI Configuration

# Base URL for ASDM platform (default: https://platform.asdm.ai)
BASE_URL=https://platform.asdm.ai

# Skip SSL certificate verification (set to 'true' for development/testing only)
# WARNING: Do not use in production environment
SKIP_SSL_VERIFICATION=true

# Override individual registry URLs (optional)
# TOOLSET_REGISTRY_URL=https://platform.asdm.ai/_ai/toolsets/registry
# SPECS_REGISTRY_URL=https://platform.asdm.ai/_ai/specs/registry
# CONTEXTS_REGISTRY_URL=
# SKILLS_REGISTRY_URL=https://platform.asdm.ai/_ai/skills/registry
